import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	    Scanner s = new Scanner(System.in);
	    int run = s.nextInt();
	    int o = s.nextInt();
	    int c = s.nextInt();
	    
	    int overs = 20-o;
	    int max = ((overs*6)*6)+c;
	    
	    if(run < max){
	        System.out.println("YES");
	    }
	    else{
	        System.out.println("NO");
	    }

	}
}
