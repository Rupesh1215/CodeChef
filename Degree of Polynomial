import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    int ans = 0;
		    
		    for(int i=0; i<n; i++){
		        int val = s.nextInt();
		        if(val != 0){
		            ans = i;
		        }
		    }
		    
		    System.out.println(ans);
		}

	}
}
