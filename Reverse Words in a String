public static String reverseWords(String s) {
    // write your code here 
    String[] words = s.trim().split("\\s+");
    StringBuilder res = new StringBuilder();
    
    for(int i=words.length-1; i>=0; i--){
        res.append(words[i]+" ");
    }
    
    String str = res.toString();
    return str;
}
