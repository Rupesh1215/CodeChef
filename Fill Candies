import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
        Scanner s = new Scanner(System.in);
        int t = s.nextInt();
        
        while(t-- > 0){
            int n = s.nextInt();
            int k = s.nextInt();
            int m = s.nextInt();
            int bags = 1;
            int candies = k*m;
            if(n%candies == 0){
                bags = bags+(n/candies)-1;
            }else{
                bags = bags+(n/candies);
            }
            
            System.out.println(bags);
        }
	}
}
