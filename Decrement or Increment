import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
        Scanner s = new Scanner(System.in);
        int a = s.nextInt();
        
        if(a%4==0){
            System.out.println(a+1);
        }
        else{
            System.out.println(a-1);
        }
	}
}
