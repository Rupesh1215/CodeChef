# cook your dish here
def max_sum(arr,k):
    
    window_sum = sum(arr[:k])
    max_sum = window_sum
    
    for i in range(k,len(arr)):
        window_sum += arr[i] - arr[i-k]
        max_sum = max(max_sum,window_sum)
    
    return max_sum

n,k = map(int,input().split())
arr = list(map(int,input().split()))

print(max_sum(arr,k))
