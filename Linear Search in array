import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner s = new Scanner(System.in);
		int n = s.nextInt();
		int k = s.nextInt();
		int[] arr = new int[n];
		
		for(int i=0; i<n; i++){
		    arr[i] = s.nextInt();
		}
		 
		 boolean flag = false;
		for(int num : arr){
		    if(num == k){
		        flag = true;
		        break;
		    }
		}
		
		if(flag){
		    System.out.println("Yes");
		}
		else{
		    System.out.println("No");
		}

	}
}
