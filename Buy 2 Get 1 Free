import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    int x = s.nextInt();
		    int items = 0;
		    
		    if(n%3 == 0){
		        items = ((n/3)*2)*x;
		    }
		    else{
		        items = (((n/3)*2)+(n%3))*x;
		    }
		    
		    System.out.println(items);
		}

	}
}
