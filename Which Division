import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    
		    if(n >= 2000){
		        System.out.println("1");
		    }
		    else if(n >= 1600 && n < 2000){
		        System.out.println("2");
		    }
		    else {
		        System.out.println("3");
		    }
		}

	}
}
