import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		char ch = s.next().charAt(0);
		
		if(ch=='A' || ch == 'E' || ch == 'I' || ch == 'O' || ch=='U'){
		    System.out.println("Vowel");
		}
		else{
		    System.out.println("Consonant");
		}

	}
}
