import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int a = s.nextInt();
		    int b = s.nextInt();
		    int c = s.nextInt();
		    int d = s.nextInt();
		    
		    int max1 = Math.max(a+c,a+d);
		    int max2 = Math.max(b+c,b+d);
		    
		    System.out.println(Math.max(max1,max2));
		}

	}
}
