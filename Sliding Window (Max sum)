# cook your dish here
def great_run(arr,k):
    
    window_sum = sum(arr[:k])
    max_sum = window_sum
    
    for i in range(k,len(arr)):
        window_sum += arr[i] - arr[i-k]
        max_sum = max(window_sum,max_sum)
    
    return max_sum

t = int(input())

for _ in range(t):
    
    n,k = map(int,input().split())
    arr = list(map(int, input().split()))
    
    result = great_run(arr,k)
    print(result)
