import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    int steps = 0;
		    for(int i=1; i<=n; i++){
		        if(i%2 == 0){
		            steps = steps-1;
		        }
		        else{
		            steps += 3;
		        }
		    }
		    
		    System.out.println(steps);
		}

	}
}
