import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    int x = s.nextInt();
		    int k = s.nextInt();
		    int bottles = k/x;
		    int ans = Math.min(n,bottles);
		    
		    System.out.println(ans);
		}

	}
}
