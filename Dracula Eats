import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int n = s.nextInt();
		    int sec = 2;
		    int ans = 0;
		    
		    while(sec <= n){
		        sec += 7;
		        ans++;
		    }
		    
		    System.out.println(ans);
		    
		}

	}
}
