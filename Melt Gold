import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int a = s.nextInt();
		    int b = s.nextInt();
		    
		    int ans = b;
		    int i = 1;
		    while(ans < a){
		        ans += i;
		        i++;
		    }
		    
		    System.out.println(i-1);
		}

	}
}
