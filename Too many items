import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		// your code goes here
        Scanner s = new Scanner(System.in);
        int t = s.nextInt();
        
        while(t-- > 0){
            int a = s.nextInt();
            
            int ans = (int)Math.ceil(a/10.0);
            System.out.println(ans);
        }
	}
}
