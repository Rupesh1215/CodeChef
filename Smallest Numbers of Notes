import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		int[] notes = {100,50,10,5,2,1};
		
		while(t-- > 0){
		   int n = s.nextInt();
		   int count = 0;
		   for(int note : notes){
		       count +=n/note;
		       n = n%note;
		       if(n==0){
		           break;
		       }
		   }
		   
		   System.out.println(count);
		}
		

	}
}
