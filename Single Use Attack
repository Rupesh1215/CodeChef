import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int h = s.nextInt();
		    int x = s.nextInt();
		    double y = s.nextDouble();
		    
		    int ans = (int)Math.ceil((h-y)/x);
		    System.out.println(ans+1);
		}

	}
}
