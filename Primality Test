import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		
        Scanner s = new Scanner(System.in);
        int t= s.nextInt();
        
        while(t-- > 0){
            int n = s.nextInt();
            int pri = 0;
            
            for(int i=1; i<n/2; i++){
                if(n%i == 0){
                    pri++;
                }
            }
            
            if(n==1){
                System.out.println("no");
            }
            else if(pri > 1){
                System.out.println("no");
            }
            else{
                System.out.println("yes");
            }
        }
	}
}
