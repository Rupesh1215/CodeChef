import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner s = new Scanner(System.in);
		int t = s.nextInt();
		
		while(t-- > 0){
		    int a = s.nextInt();
		    int b = s.nextInt();
		    int m = s.nextInt();
		    
		    int x = Math.abs(a-b);
		    int y = m-x;
		    
		    System.out.println(Math.min(x,y));
		}

	}
}
